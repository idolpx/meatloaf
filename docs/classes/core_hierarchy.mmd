%% Meatloaf core VFS classes (lib/meatloaf). Verified against source 2026-07-19.
%% Members are ordered private (-), protected (#), public (+); public members
%% whose name is not self-describing carry a short trailing description.
%% URL resolution is right-to-left: MFSOwner::File() walks the path, finds the
%% owning MFileSystem per component (by extension/scheme), and nests streams:
%%   http://srv/game.zip/disk.d64/file.prg
%%   -> HTTPMStream (container) -> ArchiveMStream -> D64MStream -> file entry
classDiagram
    direction TB

    class PeoplesUrlParser {
        +string url
        +string scheme
        +string user
        +string password
        +string host
        +string port
        +string path
        +string name
        +string extension
        +pathToFile() string - path without the trailing filename
        +base() string - url of the containing directory
        +root() string - scheme plus authority only
        +parseURL(url) unique_ptr~PeoplesUrlParser~$
    }

    class MStream {
        <<abstract>>
        #uint32_t _size
        #uint32_t _position
        #uint8_t _load_address - 2-byte C64 load address served first
        #uint8_t _error - drive error code exposed via error()
        #string _trackDirUrl - dir-as-disk track/sector emulation state
        #uint16_t _openTrack
        #openTrack(track) bool
        +openmode mode - set by MFile getSourceStream, read by seekPath writes
        +string url
        +bool has_subdirs - false for flat media images
        +size_t block_size - 256 for CBM media
        +size() uint32_t
        +available() uint32_t - bytes left before eos
        +position() uint32_t
        +position(p) bool
        +error() size_t
        +eos() bool
        +reset() void - rewind and forget served file selection
        +isOpen()* bool
        +isBrowsable() bool - true when entries are enumerated by seekNextEntry
        +isRandomAccess() bool - true when entries are selected by seekPath
        +isNetwork() bool
        +open(mode)* bool
        +close()* void
        +read(buf, size)* uint32_t
        +write(buf, size)* uint32_t
        +seek(pos)* bool
        +seek(pos, whence) bool
        +seekPath(path) bool - select a file INSIDE this stream for reading
        +seekNextEntry() string - advance flat containers one entry
        +getTrackCount() uint16_t - dir-as-disk emulation
        +getSectorCount(track) uint16_t
        +seekBlock(index, offset) bool
        +seekSector(track, sector, offset) bool
        +info() map - format-specific key/value details
    }

    class MFile {
        <<abstract>>
        -bool m_isNull
        -buildRequestUrl() string - url with cache fragment stripped
        -isCacheEnabled(mode) bool - cache=sd url fragment
        -isCacheForceRefresh() bool
        +string type - owning filesystem symbol
        +bool isPETSCII - listing names are PETSCII already
        +bool isWritable
        +string media_header - disk name for directory header line
        +string media_id - disk id shown in listings
        +string media_archive
        +string media_image
        +uint8_t media_partition
        +uint16_t media_blocks_free
        +uint16_t media_block_size
        +string pathInStream - path of the entry INSIDE the container
        +MFile* sourceFile - the container file this entry lives in
        +int is_dir - tri-state -1 unknown, 0 file, 1 dir
        +int is_hidden
        +uint32_t size
        +getSourceStream(mode) shared_ptr~MStream~ - builds container+decoded chain, calls seekPath
        +getDecodedStream(src)* shared_ptr~MStream~ - wrap container stream in format decoder
        +createStream(mode) shared_ptr~MStream~ - create-new for writes
        +openStreamWithCache(mode) shared_ptr~MStream~ - honors cache=sd fragment
        +cd(newDir) MFile* - handles CBM navigation chars
        +cdParent() MFile*
        +cdLocalParent(path) MFile*
        +cdRoot(path) MFile* - flash root
        +cdLocalRoot(path) MFile* - root of current stream
        +isDirectory() bool
        +exists() bool - stat for local, real FS check for network
        +remove() bool
        +rename(dest) bool
        +mkDir() bool
        +rmDir() bool
        +format(header_info) bool
        +rewindDirectory() bool
        +getNextFileInDir() MFile*
        +getLastWrite() time_t
        +getCreationTime() time_t
        +getAvailableSpace() uint64_t
        +blocks() uint32_t - size in media blocks for listings
        +isText() bool
        +dump() void - debug print of parsed url fields
    }

    class MFileSystem {
        <<abstract>>
        #bool _is_mounted
        +bool isRootFS - flash FS resolves bare paths
        +bool vdrive_compatible - image can be handed to VDrive
        +string service_type - DNS-SD type for mdns browsing
        +handles(path)* bool - claim a path by extension or scheme
        +getFile(path)* MFile*
        +mount() bool
        +umount() bool
        +isMounted() bool
        +byExtension(ext, path) bool$
        +byContent(header) string$ - sniff extension from magic bytes
    }

    class MFSOwner {
        <<static>>
        +availableFS$ - ordered registry, first handles() match wins
        +availableOther$ - encoder/link/loader/wrapper schemes
        +File(path) MFile*$ - THE entry point: right-to-left resolution
        +File(path, default_fs) MFile*$
        +findParentFS(begin, end) MFileSystem*$
    }

    class MMediaStream {
        <<abstract>>
        #bool seekCalled - a file inside the image is selected; read() caps at _size
        #shared_ptr~MStream~ containerStream
        #bool _is_open
        #size_t media_header_size
        #size_t media_data_offset
        #size_t entry_index - 1-based current directory entry, 0 none
        #bool show_hidden
        +readContainer(buf, size) uint32_t - raw image bytes
        +readFile(buf, size)* uint32_t - bytes of the SELECTED file
        +writeFile(buf, size)* uint32_t
        +readHeader() bool
        +writeHeader(name, id) bool
        +seekEntry(filename) bool
        +seekEntry(index) bool
        +getNextImageEntry() bool
        +resetEntryCounter() void
        +seekFileSize(track, sector) uint32_t - walk block chain to count bytes
        +decodeType(file_type, hidden) string - CBM file type text
        +readUntil(delimiter) string
        +readString(size) string
        +blocks() uint32_t
        +blocksFree() uint16_t
        +seekPath(path) bool
        +seekNextEntry() string
    }

    class ImageBroker {
        <<static>>
        -image_repo$ - map key = type + container url
        -lru_order$ - oldest first, max 50 entries
        -is_in_use(key) bool$ - skip eviction for mounted cwds
        -evict_lru_if_needed()$
        -cleanup_old_entries()$ - every 60 s
        -touch_entry(key)$
        +obtain(type, url)$ - shared decoded image; creates on first use
        +exists(url) bool$
        +dispose(type, url)$ - force re-decode (partition change)
    }

    class MSession {
        <<abstract>>
        #bool connected
        #string session_key
        #uint32_t keep_alive_interval - ms; 0 disables (stateless protocols: NFS, FSP)
        +connect()* bool
        +disconnect()* void
        +keep_alive()* bool - periodic ping from the broker task
        +refresh() bool - re-list or re-auth after reconnect
        +isConnected() bool
        +setKeepAliveInterval(ms) void
        +getKeepAliveInterval() uint32_t
    }

    class CachedFile {
        -m_sdPath string - SD-backed variant
        -bool m_useHimem
        -freeStorage() void
        -s_ramCache$ - keyed RAM cache of extracted entries
        +uint32_t size
        +bool dirty
        +allocate() bool - HIMEM page-mapped on SPIRAM boards, heap otherwise
        +isAllocated() bool
        +read(offset, buf, count) uint32_t
        +write(offset, buf, count) uint32_t
        +loadFromStream(stream, fileSize) bool
        +loadViaReader(fileSize, reader) bool - fill via callback in HIMEM-block chunks
        +forSD(sdPath) shared_ptr~CachedFile~$
        +getRAMCached(key) shared_ptr~CachedFile~$
        +setRAMCached(key, cf) void$
        +clearRAMCached(key) void$
    }

    class SessionBroker {
        <<static>>
        -session_repo$ - map key = host colon port
        -bool task_running - keep-alive task, 8 KB stack (do not shrink)
        -SemaphoreHandle_t _mutex$
        -lock()$
        -unlock()$
        -session_host_key(key) string$
        -path_matches_session(path, key) bool$
        -is_session_in_use(key) bool$ - protects active sessions from cleanup
        +obtain(host, port)$ - reuse or create the protocol session
        +service()$ - periodic keep-alive sweep
    }

    class mfilebuf {
        <<std::streambuf>>
        -shared_ptr~MStream~ mstream
        -char* gbuffer - 2 KB PSRAM get buffer
        +underflow() int - refills gbuffer; guards gptr GTE egptr
        +overflow(c) int
        +sync() int
        +is_open() bool
        +open(url, mode) bool
        +close() void
    }

    class basic_fstream {
        <<Meat::iostream>>
        +nda() bool - no-data-available state (ndabit) for non-blocking reads
        +get() int
        +getUtf8() U8Char
    }

    class csstreambuf {
        <<std::streambuf>>
        +console/serial sink
    }
    class idirbuf {
        <<std::streambuf>>
        +directory listing source
    }

    PeoplesUrlParser <|-- MFile
    MStream <|-- MMediaStream
    MFile ..> MStream : getSourceStream() chains container to decoded
    MFileSystem ..> MFile : getFile()
    MFSOwner ..> MFileSystem : right-to-left path match
    MFSOwner ..> MFile : creates
    ImageBroker o-- MMediaStream : LRU cache keyed type+url
    SessionBroker o-- MSession : keyed host-port, keep-alive task
    MSession *-- CachedFile : PSRAM/HIMEM/SD entry cache
    basic_fstream *-- mfilebuf
    mfilebuf ..> MStream : buffered reads

    note for MStream "Sentinel _MEAT_NO_DATA_AVAIL (0xFFFFFFFE, int -2) returned by non-blocking reads; must never collide with a real byte count or EOF (-1)"
    note for MFile "exists() uses stat() for local paths; network FS override with a real check (e.g. fsp_stat). Never infer existence from a lazy stream open"
