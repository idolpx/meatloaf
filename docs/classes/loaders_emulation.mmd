%% Tape loader analysis engine (components/tapclean) and codecs.
%% Verified against source 2026-07-19.
%% The TAPClean engine is vendored C (TAPClean 0.39 / Final TAP 2.76,
%% GPL v2+), compiled with TAPCLEAN_EMBEDDED: CLI/report/clean code is
%% compiled out, all big buffers are heap-allocated (PSRAM-first) only
%% while a tape is being analyzed, and malloc() is redirected engine-wide
%% to tapclean_psram_malloc().
classDiagram
    direction TB

    class tapclean_api {
        <<C API - components/tapclean/include/tapclean_api.h>>
        +tapclean_init() int - lazy: allocates all engine buffers PSRAM-first
        +tapclean_shutdown() void - frees EVERYTHING incl. loaded tape
        +tapclean_load_buffer(buf, len, machine, ntsc) int - takes ownership of buf
        +tapclean_load_buffer_ref(buf, len, machine, ntsc) int - borrows buf (window re-scans)
        +tapclean_analyze_tap(unite_blocks) int - full scan; returns PRG count
        +tapclean_unload() void - free tape, keep work buffers
        +tapclean_block_count() int
        +tapclean_get_block(idx, out) int - raw block records (tapclean_block_t)
        +tapclean_prg_count() int
        +tapclean_get_prg(idx, out) int - united programs (tapclean_prg_t)
        +tapclean_detected_percent() int - pulses accounted for
        +tapclean_tap_time_ms() uint - whole-tape play time
        +tapclean_time_at_ms(offset) uint - play time from start to offset
        +tapclean_offset_at_ms(ms) int - inverse: tape counter seek
        +tapclean_duration_ms(p1, p2) uint - play time between offsets
    }

    class tapclean_engine {
        <<C internals - components/tapclean/src>>
        +search_tap() pause+CBM, loader-ID shortcut, 90 scanners
        +describe_blocks() decode data and checksums
        +idloader(crc, len) CBM boot CRC and code signatures
        +database_add_blk_def() early exit at 97 pct coverage
        +database_make_prg_db() unite neighbouring blocks
        +readttbit() find_pilot() pulse readers with yield and dots
        +tapclean_psram_malloc() engine-wide PSRAM allocation
    }

    class tapclean_scanners {
        <<91 scanner modules>>
        +turbotape_search() describe()
        +turbotape_fast_search() describe() Meatloaf addition
        +cyberload_f1..f4, visiload, usgold, novaload
        +freeload, pavloda, ocean, bleep, snakeload, more
    }

    class tapclean_prg_t {
        <<struct>>
        +int type
        +const char* type_name
        +int is_cbm_header
        +int is_cbm_data
        +int start_addr, end_addr, size
        +const char* name
        +const uint8_t* data
        +int read_errors
        +int tap_start, tap_end
    }

    class TapeDecoder {
        -MStream* stream - container being fetched
        -uint8_t window - 16 KB stream window for conversion reads
        -uint8_t kind - TAP, DMP or HTAP
        -uint8_t version
        -uint8_t platform - C64, VIC20, C16
        -uint8_t video - PAL or NTSC
        -bool halfwaves - HTAP and TAP v2 sum pairs
        -bool converting - source needs TAP v1 conversion
        -bool fully_scanned
        -uint8_t* image - (converted) image prefix in PSRAM
        -uint32_t image_cap
        -uint32_t fetched - valid bytes of image (== bytes scanned)
        -uint32_t conv_pos - container read cursor while converting
        -bool conv_eof
        -vector~TapeEntry~ entries - confirmed programs in tape order
        -uint32_t total_ms
        -readBytes(pos, dst, n) bool
        -nextValue(pos, cycles) bool - one pulse or halfwave from container
        -machineClock() uint32_t
        -extendScan() bool - grow window 512K doubling, fetch + scan
        -fetchTo(target) bool - raw fetch or streamed conversion
        -appendValue(cycles) bool - encode one v1 pulse into image
        -scanWindow(win) bool - borrowed-buffer TAPClean scan, rebuild entries
        -harvestEntries(nprg) void - filter boot stubs, dedup repeats, name transfer
        -finishScan() void - free image once fully analyzed
        +open(container) bool - header parse only; scanning is on demand
        +isOpen() bool
        +dataStart() uint32_t
        +imageLen() uint32_t
        +nextProgram(from_offset, out) bool - first entry ending past offset; may extend scan
        +resetContinuation() void - interface compat, no-op
        +offsetAtTime(ms) uint32_t - tape counter seek, snaps to program grid
        +totalMs() uint32_t - forces full scan
    }

    namespace RetroPixelsCodec {
        class IImageData
        class PixelImage
        class GraphicMode
        class Palette
        class Quantizer
        class Converter
        class RetroPixelsConfig
        class RetroPixelsMStream
    }

    class QRMStream {
        <<codec/qr.h>>
        +QR code generator stream
    }

    class HighMemory {
        <<device/ram.h>>
        +ESP32 HIMEM page mapping
    }
    class HighMemoryHandle

    class Audio {
        <<lib/audio>>
    }

    class samlib {
        <<lib/sam - C functions>>
        +SAM speech synthesizer
    }

    tapclean_api ..> tapclean_engine : TAPCLEAN_EMBEDDED build
    tapclean_engine *-- tapclean_scanners : search_tap() dispatch
    tapclean_api ..> tapclean_prg_t : result records
    TapeDecoder --> tapclean_api : progressive window scans (see media_scanner.mmd)

    Converter ..> PixelImage
    Converter ..> GraphicMode
    Quantizer ..> Palette
    RetroPixelsMStream ..> Converter : image -> koala/hires
    RetroPixelsMStream ..> RetroPixelsConfig

    HighMemory ..> HighMemoryHandle
    Audio ..> samlib : speech output

    note for tapclean_engine "Loader-ID fast path: idloader() identifies the loader from the CBM boot block (CRC table + code signatures incl. the Turbo Tape 64 fast IRQ stub) so identified tapes scan pause+CBM+that loader only; unidentified tapes run all scanners with an early exit once 97% of the tape is accounted for"
    note for tapclean_scanners "Formats table ft[] (PSRAM working copy of const flash defaults); TTFAST entries tp=$0E sp=$0B lp=$12 (116/88/144 cycles)"
