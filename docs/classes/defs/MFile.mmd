    class MFile {
        <<abstract>>
        -bool m_isNull
        -buildRequestUrl() string - url with cache fragment stripped
        -isCacheEnabled(mode) bool - cache=sd url fragment
        -isCacheForceRefresh() bool
        +string type - owning filesystem symbol
        +bool isPETSCII - listing names are PETSCII already
        +bool isWritable
        +string media_header - disk name for directory header line
        +string media_id - disk id shown in listings
        +string media_archive
        +string media_image
        +uint8_t media_partition
        +uint16_t media_blocks_free
        +uint16_t media_block_size
        +string pathInStream - path of the entry INSIDE the container
        +MFile* sourceFile - the container file this entry lives in
        +int is_dir - tri-state -1 unknown, 0 file, 1 dir
        +int is_hidden
        +uint32_t size
        +getSourceStream(mode) shared_ptr~MStream~ - builds container+decoded chain, calls seekPath
        +getDecodedStream(src)* shared_ptr~MStream~ - wrap container stream in format decoder
        +createStream(mode) shared_ptr~MStream~ - create-new for writes
        +openStreamWithCache(mode) shared_ptr~MStream~ - honors cache=sd fragment
        +cd(newDir) MFile* - handles CBM navigation chars
        +cdParent() MFile*
        +cdLocalParent(path) MFile*
        +cdRoot(path) MFile* - flash root
        +cdLocalRoot(path) MFile* - root of current stream
        +isDirectory() bool
        +exists() bool - stat for local, real FS check for network
        +remove() bool
        +rename(dest) bool
        +mkDir() bool
        +rmDir() bool
        +format(header_info) bool
        +rewindDirectory() bool
        +getNextFileInDir() MFile*
        +getLastWrite() time_t
        +getCreationTime() time_t
        +getAvailableSpace() uint64_t
        +blocks() uint32_t - size in media blocks for listings
        +isText() bool
        +dump() void - debug print of parsed url fields
    }
